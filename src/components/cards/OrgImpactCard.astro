---
import MarkEmblem from '@components/ui/MarkEmblem.astro';
import type { VisionBoard } from '@schemas';

// SSOT: props derive from the vision-board `orgCards` schema item.
type Props = NonNullable<VisionBoard['orgCards']>[number];

const { mark, title, lines } = Astro.props;
---

<article class="ocard">
  <div class="ocard__icon" aria-hidden="true">
    <MarkEmblem mark={mark} iconSize={28} />
  </div>
  <h3 class="ocard__title">{title}</h3>
  <div class="ocard__rule" aria-hidden="true"></div>
  <div class="ocard__body">
    {lines.map((line) => <p>{line}</p>)}
  </div>
</article>

<style>
  .ocard {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 4;
    row-gap: 0;
    background: var(--bg-elev);
    border-radius: var(--radius-xl);
    min-height: 210px;
    padding: var(--card-padding-lg) var(--card-padding) var(--card-padding);
    text-align: center;
    box-shadow: var(--shadow);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  /* Top gradient bar. */
  .ocard::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 6px;
    background: linear-gradient(90deg, var(--accent), var(--accent-strong));
  }
  /* Left purple→red gradient bar. */
  .ocard::after {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 6px;
    background: linear-gradient(
      180deg,
      var(--accent),
      var(--accent-strong) 70%,
      var(--accent-red)
    );
  }
  .ocard:hover {
    transform: translateY(var(--card-lift));
    box-shadow: var(--shadow-md);
  }
  .ocard__icon {
    width: var(--vision-org-icon, 60px);
    height: var(--vision-org-icon, 60px);
    border-radius: 50%;
    margin: var(--space-2) auto var(--space-4);
    display: grid;
    place-items: center;
    color: var(--accent-contrast);
    background: radial-gradient(
      circle at 30% 30%,
      var(--accent-strong),
      var(--accent)
    );
  }
  /* Fixed glyph box keeps every emblem the same visible size, centred by the
     wrapper's place-items; the mask stays aspect-preserving (matches HubCircle). */
  .ocard__icon :global(.mark-emblem) {
    width: var(--vision-org-glyph, 44px);
    height: var(--vision-org-glyph, 44px);
  }
  .ocard__title {
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
    color: var(--accent);
  }
  .ocard__rule {
    width: 92%;
    height: 2px;
    margin: var(--space-3) auto var(--space-4);
    background: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--text-muted) 50%, transparent) 0 2px,
      transparent 2px 5px
    );
  }
  .ocard__body {
    display: grid;
    gap: var(--space-1);
    min-height: 2.5lh;
    align-content: start;
  }
  .ocard__body p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-muted);
    text-wrap: balance;
  }
</style>
