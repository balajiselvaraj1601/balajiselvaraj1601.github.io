---
import Section from '@components/ui/Section.astro';
import ProjectAccordion from '@components/cards/ProjectAccordion.astro';
import CardMark from '@components/ui/CardMark.astro';
import Chip from '@components/ui/Chip.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { experience, getEntityUrl, logoSrc } from '@lib/content';
import { logoUsesBadge } from '@lib/logo-display';

function periodLabel(p: {
  start: string;
  end: string | null;
  endLabel: string;
}) {
  const end = p.endLabel || p.end || '';
  return end ? `${p.start} – ${end}` : p.start;
}

const headline = experience.headline ?? experience.title;
---

<Section
  id="experience"
  title=""
  hideTitle
  labelledBy="experience-heading"
  variant="alt"
  class="section--compact-top"
>
  <div class="section-header">
    <SectionHeading
      title={headline}
      highlight={experience.headlineHighlight}
      class="section__title"
      id="experience-heading"
    />
  </div>
  <ol class="xp-stack" aria-label="Career timeline">
    {
      experience.roles.map((role, i) => (
        <li class:list={['xp-role', 'reveal']}>
          <div
            class:list={['xp-marker', { 'is-current': i === 0 }]}
            aria-hidden="true"
          />
          <article>
            <header class="xp-head">
              {logoSrc(role.entity) && (
                <CardMark
                  slug={role.entity}
                  logoUrl={logoSrc(role.entity)}
                  altText={`${role.organization} logo`}
                  useBadge={logoUsesBadge(role.entity)}
                />
              )}
              <p class="xp-meta">
                {periodLabel(role.period)}
                {role.location && (
                  <>
                    <span class="xp-meta__sep" aria-hidden="true">
                      ·
                    </span>
                    {role.location}
                  </>
                )}
              </p>
              <h3 class="xp-title">{role.position}</h3>
              <p class="xp-org">
                <EntityLink
                  href={getEntityUrl(role.entity)}
                  label={role.organization}
                />
              </p>
              {role.blurb && <p class="xp-blurb">{role.blurb}</p>}
              {role.tech && role.tech.length > 0 && (
                <div class="xp-tech">
                  {role.tech.map((t) => (
                    <Chip>{t}</Chip>
                  ))}
                </div>
              )}
            </header>
            <div class="xp-projects">
              {role.projects.map((project) => (
                <ProjectAccordion
                  name={project.name}
                  subtitle={project.subtitle}
                  icon={project.icon}
                  bullets={project.bullets}
                />
              ))}
            </div>
          </article>
        </li>
      ))
    }
  </ol>
</Section>

<style>
  .xp-stack {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--stack-xl);
    max-width: 760px;
  }
  .xp-stack::before {
    content: '';
    position: absolute;
    left: var(--space-2);
    top: var(--space-2);
    bottom: var(--space-2);
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--accent),
      var(--accent-red),
      transparent
    );
  }
  .xp-role {
    position: relative;
    padding-left: var(--space-10);
  }
  .xp-marker {
    position: absolute;
    left: 0;
    top: var(--space-1);
    width: var(--space-5);
    height: var(--space-5);
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
  }
  .xp-marker.is-current {
    background: var(--accent);
  }
  .xp-head {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap-inline);
    margin-bottom: var(--stack-sm);
  }
  .xp-meta {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    color: var(--accent-light);
    display: flex;
    gap: var(--space-2);
    margin: 0;
  }
  .xp-meta__sep {
    color: var(--text-muted);
    opacity: 0.6;
  }
  .xp-title {
    font-size: var(--fs-xxl);
    font-weight: var(--fw-bold);
    margin: 0;
  }
  .xp-org {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin: 0;
  }
  .xp-blurb {
    font-size: var(--fs-body);
    color: var(--text-muted);
    line-height: var(--lh-relaxed);
    max-width: var(--maxw-text);
    margin: 0;
  }
  .xp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--text-gap-pair);
  }
  .xp-projects {
    display: flex;
    flex-direction: column;
    gap: var(--stack-sm);
  }
  @media (max-width: 560px) {
    .xp-role {
      padding-left: var(--space-8);
    }
  }
</style>
