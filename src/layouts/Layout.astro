---
import '../styles/global.css';
import BaseHead from '@components/chrome/BaseHead.astro';
import ThemeScript from '@components/chrome/ThemeScript.astro';
import Header from '@components/chrome/Header.astro';
import Footer from '@components/chrome/Footer.astro';
import DotNav from '@components/chrome/DotNav.astro';
import HeroCanvas from '@components/cards/HeroCanvas.astro';
import { navViews } from '@lib/content';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  chrome?: boolean;
  dotNavSections?: string[];
  singlePageViews?: boolean;
}
const {
  title,
  description,
  path = '/',
  chrome = true,
  dotNavSections = [],
  singlePageViews = false,
} = Astro.props;

const homeView = navViews.find((v) => v.id === 'home');
const navViewsConfig = singlePageViews
  ? {
      views: navViews.map((v) => ({
        viewAnchor: v.viewAnchor,
        viewSections: v.viewSections,
      })),
      defaultView: homeView?.viewAnchor ?? 'about',
    }
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeScript />
    <BaseHead title={title} description={description} path={path} />
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <HeroCanvas />
    <a href="#main" class="skip-link">Skip to content</a>
    {chrome && <Header singlePageViews={singlePageViews} />}
    {chrome && dotNavSections.length >= 2 && (
      <DotNav sections={dotNavSections} singlePageViews={singlePageViews} />
    )}
    <main id="main">
      <slot />
    </main>
    {chrome && <Footer />}
    {
      chrome && navViewsConfig && (
        <script define:vars={{ navViewsConfig }}>
          import { initSiteChrome } from '../scripts/site-chrome';
          initSiteChrome(navViewsConfig);
        </script>
      )
    }
    {
      chrome && !navViewsConfig && (
        <script>
          import { initSiteChrome } from '../scripts/site-chrome';
          initSiteChrome();
        </script>
      )
    }
  </body>
</html>

<style is:global>
  body {
    padding-top: var(--header-h);
  }
</style>
