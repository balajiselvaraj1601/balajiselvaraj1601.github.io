---
import Section from '@components/ui/Section.astro';
import XpCompanyCard from '@components/sections/experience/XpCompanyCard.astro';
import XpWorkGroup from '@components/sections/experience/XpWorkGroup.astro';
import { experience, site } from '@lib/content';

function periodLabel(p: {
  start: string;
  end: string | null;
  endLabel: string;
}) {
  const end = p.endLabel || p.end || '';
  return end ? `${p.start} – ${end}` : p.start;
}

/** Fallback stop label when a role has no authored orgShort (full name lives in the company block). */
function orgShortFallback(organization: string) {
  return organization.split(',')[0];
}
---

<Section
  id="experience"
  title={experience.title}
  eyebrow={site.sections.experience.eyebrow}
  subtitle={experience.intro}
  variant="default"
>
  <div class="xp-timebar reveal">
    <div
      class="xp-timebar__track"
      role="tablist"
      aria-label="Career timeline"
      data-xp-timebar
    >
      {
        experience.roles.map((role, i) => (
          <button
            type="button"
            role="tab"
            id={`xp-tab-${role.id}`}
            class:list={[
              'xp-stop',
              role.level && `xp-level-${role.level}`,
              { 'is-active': i === 0 },
            ]}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`xp-${role.id}`}
            tabindex={i === 0 ? 0 : -1}
            data-xp-tab
          >
            <span class="xp-stop__marker" aria-hidden="true" />
            <span class="xp-stop__period">{periodLabel(role.period)}</span>
            <span class="xp-stop__org">
              {role.orgShort ?? orgShortFallback(role.organization)}
            </span>
          </button>
        ))
      }
    </div>
  </div>

  <div class="xp-panels reveal">
    {
      experience.roles.map((role, i) => (
        <div
          class:list={[
            'xp-panel',
            role.level && `xp-level-${role.level}`,
            { 'is-active': i === 0 },
          ]}
          id={`xp-${role.id}`}
          role="tabpanel"
          aria-labelledby={`xp-tab-${role.id}`}
          data-xp-panel
        >
          <XpCompanyCard role={role} periodLabel={periodLabel(role.period)} />
          <XpWorkGroup role={role} />
        </div>
      ))
    }
  </div>
</Section>

<style>
  /* Per-role seniority accent — maps each career level onto a shared --lvl-* hue
     (present → past spectrum). Both the timeline stop and its panel feed
     --accent-card, so the marker, active label, company logo badge, and project
     marks all inherit the role's hue. */
  .xp-level-principal {
    --lvl: var(--lvl-cio);
  } /* purple */
  .xp-level-staff {
    --lvl: var(--lvl-senior-director);
  } /* blue */
  .xp-level-senior {
    --lvl: var(--lvl-director);
  } /* teal */
  .xp-level-lead {
    --lvl: var(--lvl-evp);
  } /* gold */
  .xp-level-associate {
    --lvl: var(--lvl-national);
  } /* pink */
  .xp-level-engineer {
    --lvl: var(--lvl-associate-director);
  } /* red */
  .xp-stop,
  .xp-panel {
    --accent-card: var(--lvl, var(--accent));
  }

  /* ---- Horizontal timeline bar (role selector; JS-only control) ---- */
  .xp-timebar {
    overflow-x: auto;
    margin-bottom: var(--stack-sm);
    scroll-snap-type: x proximity;
  }
  :global(html:not(.js)) .xp-timebar {
    display: none;
  }
  .xp-timebar__track {
    position: relative;
    display: flex;
    min-width: max-content;
    width: 100%;
  }
  /* Continuous line through the markers — same gradient language as the
     old vertical rail (accent = present, fading toward the past). */
  .xp-timebar__track::before {
    content: '';
    position: absolute;
    top: calc(var(--space-4) / 2);
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      to right,
      var(--accent),
      var(--accent-red),
      transparent
    );
  }
  .xp-stop {
    position: relative;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: 0;
    padding: 0 var(--space-4) var(--space-2);
    font: inherit;
    color: inherit;
    cursor: pointer;
    white-space: nowrap;
    scroll-snap-align: center;
  }
  .xp-stop:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
  .xp-stop__marker {
    width: var(--space-4);
    height: var(--space-4);
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent-card, var(--accent));
    transition: background var(--dur) var(--ease);
  }
  .xp-stop.is-active .xp-stop__marker {
    background: var(--accent-card, var(--accent));
  }
  .xp-stop__period {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    color: var(--text-muted);
    transition: color var(--dur) var(--ease);
  }
  .xp-stop:hover .xp-stop__period {
    color: var(--text);
  }
  .xp-stop.is-active .xp-stop__period {
    color: var(--accent-card, var(--accent-light));
  }
  .xp-stop__org {
    font-size: var(--fs-small);
    color: var(--text-muted);
  }
  .xp-stop.is-active .xp-stop__org {
    color: var(--heading);
  }

  /* ---- Role panels: one visible with JS, all stacked without ---- */
  .xp-panels {
    display: flex;
    flex-direction: column;
    gap: var(--stack-lg);
  }
  .xp-panel {
    display: flex;
    flex-direction: column;
    gap: var(--stack-sm);
  }
  :global(html.js) .xp-panel:not(.is-active) {
    display: none;
  }
  :global(html.js) .xp-panel.is-active {
    animation: xp-panel-in var(--dur-slow) var(--ease);
  }
  @keyframes xp-panel-in {
    from {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .xp-panel.is-active {
      animation: none;
    }
  }

  /* Company block styles → experience/XpCompanyCard.astro;
     work-group (Key Projects) styles → experience/XpWorkGroup.astro. */
</style>
