---
import Section from '@components/ui/Section.astro';
import MetricCard from '@components/cards/MetricCard.astro';
import { visionBoard, site } from '@lib/content';
---

<Section
  id="vision-intro"
  title={visionBoard.header}
  eyebrow={site.sections['vision-intro'].eyebrow}
  subtitle={visionBoard.intro}
  variant="default"
  class="section--compact-bottom"
>
  {
    visionBoard.snapshot && visionBoard.snapshot.length > 0 && (
      <div class="snapshot-grid reveal">
        {visionBoard.snapshot.map((m) => (
          <MetricCard value={m.value} label={m.label} />
        ))}
      </div>
    )
  }
</Section>
