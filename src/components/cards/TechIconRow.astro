---
interface TechItem {
  label: string;
  icon?: string;
}

interface Props {
  items: TechItem[];
  /** Optional eyebrow rendered above the chip row. */
  eyebrow?: string;
  class?: string;
}

const { items, eyebrow, class: cls } = Astro.props;
---

{items.length > 0 && (
  <div class:list={['tech-row', cls]} aria-label={eyebrow ?? 'Core technologies'}>
    {eyebrow && <span class="tech-row__eyebrow">{eyebrow}</span>}
    <ul class="tech-row__list">
      {items.slice(0, 6).map((item) => (
        <li class="tech-row__chip">
          <span class="tech-row__label">{item.label}</span>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .tech-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tech-row__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .tech-row__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tech-row__chip {
    display: inline-flex;
    align-items: center;
    padding: 0.32rem 0.7rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-elev);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    line-height: 1;
    transition: border-color var(--dur) var(--ease),
      color var(--dur) var(--ease);
  }
  .tech-row__chip:hover {
    border-color: var(--accent-light);
    color: var(--accent-ll);
  }
  .tech-row__label {
    white-space: nowrap;
  }
</style>
