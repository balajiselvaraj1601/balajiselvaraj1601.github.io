---
import Section from '@components/Section.astro';
import ProjectCaseStudyCard from '@components/ProjectCaseStudyCard.astro';
import { projects, site } from '@lib/content';

const featured = projects.projects.filter((p) => p.featured);
const title = site.sections['featured-case-studies'].title;
---

<Section
  id="featured-case-studies"
  title={title}
  eyebrow="Flagship Work"
  variant="alt"
>
  <div class="case-study-stack reveal">
    {
      featured.map((p) => (
        <ProjectCaseStudyCard
          name={p.name}
          role={p.role}
          org={p.org}
          period={p.period}
          domain={p.domain}
          summary={p.summary}
          tags={p.tags}
          problem={p.problem}
          solution={p.solution}
          architecture={p.architecture}
          businessImpact={p.businessImpact}
          outcome={p.outcome}
          lessons={p.lessons}
        />
      ))
    }
  </div>
</Section>

<style>
  .case-study-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
</style>
