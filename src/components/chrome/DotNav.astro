---
import type { DotNavView } from '@lib/content';
import { site } from '@lib/content';

interface Props {
  views: DotNavView[];
}
const { views } = Astro.props;
const { dotNav } = site.ui;
---

<nav
  class="dot-nav"
  id="dot-nav"
  aria-label={dotNav.ariaLabel}
  hidden={views.length < 2}
>
  {
    views.map((view) => (
      <button
        type="button"
        class="dot-nav__dot"
        data-dot-id={view.id}
        data-scroll-section={view.scrollSection}
        title={view.label}
        aria-label={view.label}
        hidden
      />
    ))
  }
</nav>

<style>
  .dot-nav {
    position: fixed;
    right: 2.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .dot-nav[hidden] {
    display: none;
  }
  .dot-nav__dot {
    width: var(--size-dot);
    height: var(--size-dot);
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: var(--text-muted);
    cursor: pointer;
    transition:
      background var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }
  .dot-nav__dot[hidden] {
    display: none;
  }
  .dot-nav__dot:hover {
    background: var(--accent-ll);
  }
  .dot-nav__dot.is-active {
    background: var(--accent-light);
    transform: scale(1.5);
  }
  .dot-nav__dot:focus-visible {
    outline: 2px solid var(--accent-light);
    outline-offset: 3px;
  }
  @media (max-width: 900px) {
    .dot-nav {
      display: none;
    }
  }
</style>
