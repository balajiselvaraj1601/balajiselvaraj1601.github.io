---
import Section from '@components/ui/Section.astro';
import JourneyRow from '@components/cards/JourneyRow.astro';
import LeadershipCard from '@components/cards/LeadershipCard.astro';
import MetricCard from '@components/cards/MetricCard.astro';
import Icon from '@components/ui/Icon.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { strategicImpact, site } from '@lib/content';

const meta = site.sections.impact;
const title = strategicImpact.headline ?? meta.title;
const highlight = strategicImpact.headlineHighlight;
---

<Section
  id="impact"
  title=""
  hideTitle
  labelledBy="impact-heading"
  variant="impact"
  class="impact-section"
>
  <div class="section-header section-header--center">
    <p class="eyebrow">{meta.eyebrow!}</p>
    <SectionHeading
      title={title}
      highlight={highlight}
      class="section__title"
      align="center"
      id="impact-heading"
    />
    <p class="section__subtitle">{strategicImpact.subtitle}</p>
  </div>

  {
    strategicImpact.journey && strategicImpact.journey.length > 0 && (
      <JourneyRow journey={strategicImpact.journey} />
    )
  }

  {
    strategicImpact.metrics.length > 0 && (
      <div class="impact-metrics reveal" aria-label="Strategic impact metrics">
        {strategicImpact.metrics.map((metric) => (
          <MetricCard value={metric.value} label={metric.label} />
        ))}
      </div>
    )
  }

  <div class="impact-cta reveal">
    <a class="btn btn-secondary impact-cta__link" href="/#projects">
      {meta.ctaLabel!}
      <Icon name="arrow-right" size="sm" />
    </a>
  </div>

  {
    strategicImpact.leadershipCards &&
      strategicImpact.leadershipCards.length > 0 && (
        <div class="leadership-block reveal">
          <p class="eyebrow eyebrow--red leadership-block__eyebrow">
            {meta.subEyebrow!}
          </p>
          <div class="leadership-cards">
            {strategicImpact.leadershipCards.map((c) => (
              <LeadershipCard {...c} />
            ))}
          </div>
        </div>
      )
  }

  {
    strategicImpact.highlights.length > 0 && (
      <ul class="impact-highlights reveal">
        {strategicImpact.highlights.map((item) => (
          <li>{item.text}</li>
        ))}
      </ul>
    )
  }
</Section>

<style>
  .impact-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-4);
    margin: var(--text-gap-section) 0 var(--space-12);
  }
  .impact-cta {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-12);
  }
  .impact-cta__link {
    gap: var(--space-2);
  }
  @media (prefers-reduced-motion: no-preference) {
    .impact-cta__link:hover {
      gap: var(--space-3);
    }
  }
  .leadership-block {
    margin-top: var(--stack-xl);
  }
  .leadership-block__eyebrow {
    margin-bottom: var(--text-gap-section);
  }
  .leadership-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--stack-sm);
  }
  .impact-highlights {
    list-style: none;
    padding: 0;
    margin: var(--space-10) auto 0;
    max-width: 820px;
    display: grid;
    gap: var(--space-4);
  }
  .impact-highlights li {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-5);
    color: var(--text);
    line-height: var(--lh-relaxed);
  }
</style>
