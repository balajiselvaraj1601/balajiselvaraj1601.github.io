---
import Section from '@components/Section.astro';
import ProjectAccordion from '@components/ProjectAccordion.astro';
import { projectIcon } from '@lib/icons';
import { projects, site } from '@lib/content';

const featured = projects.projects.filter((p) => p.featured).slice(0, 3);
const title = site.sections['featured-projects'].title;
---

<Section id="featured-projects" title={title} variant="alt">
  <div class="projects-list reveal">
    {
      featured.map((p, i) => (
        <ProjectAccordion
          name={p.name}
          subtitle={`${p.role} · ${p.domain}`}
          icon={projectIcon(p.domain, p.id)}
          bullets={p.highlights}
          open={i === 0}
        />
      ))
    }
  </div>
  <p class="featured-more reveal">
    <a class="btn btn-secondary" href="/projects">View all projects →</a>
  </p>
</Section>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .featured-more {
    margin-top: var(--space-8);
    max-width: none;
  }
</style>
