# Copy to .cursor/site-review.env and edit (gitignored).
# Used by site-review-{arm,run,status}.sh

SITE_REVIEW_MODEL="claude-fable-5-thinking-high"
SITE_REVIEW_DELAY_MINUTES="180"
SITE_REVIEW_EXTRA_FLAGS="--force --auto-review --approve-mcps"
SITE_REVIEW_ALLOW_COMMIT="true"
SITE_REVIEW_GOAL="Detailed full-site review: audit all sections, content SSOT, a11y, build/CI, design consistency; fix every issue found; verify and commit."

# Optional API key (otherwise agent uses stored Cursor auth).
# CURSOR_API_KEY=""
