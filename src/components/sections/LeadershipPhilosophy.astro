---
import Section from '@components/ui/Section.astro';
import Icon from '@components/ui/Icon.astro';
import {
  profile,
  site,
  collaborations,
  getEntityUrl,
  logoSrc,
} from '@lib/content';

const title = site.sections.leadership.title;
const { statement, intro, differentiators, themes } =
  profile.leadershipPhilosophy;
const { aboutCards } = profile;
---

<Section id="leadership" title={title} variant="default">
  {statement && <p class="leadership__statement reveal">{statement}</p>}

  <p class="leadership__bio reveal">{profile.aboutIntro}</p>

  {
    aboutCards && aboutCards.length > 0 && (
      <ul class="leadership__themes reveal" role="list">
        {aboutCards.map((card) => (
          <li class="leadership__theme card">
            <h3 class="leadership__theme-title">{card.title}</h3>
            <ul class="bullet-list">
              {card.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    )
  }

  {intro && <p class="leadership__intro reveal">{intro}</p>}

  {
    differentiators && differentiators.length > 0 && (
      <div class="leadership__diff reveal">
        <h3 class="leadership__diff-heading">What sets me apart</h3>
        <ul class="leadership__themes" role="list">
          {differentiators.map((item) => (
            <li class="leadership__theme card">
              {item.icon && (
                <span class="leadership__theme-icon" aria-hidden="true">
                  <Icon name={item.icon} size={22} />
                </span>
              )}
              <h4 class="leadership__theme-title">{item.title}</h4>
              <p class="leadership__theme-desc">{item.description}</p>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    themes && themes.length > 0 && (
      <ul class="leadership__themes reveal" role="list">
        {themes.map((theme) => (
          <li class="leadership__theme card">
            {theme.icon && (
              <span class="leadership__theme-icon" aria-hidden="true">
                <Icon name={theme.icon} size={22} />
              </span>
            )}
            <h3 class="leadership__theme-title">{theme.title}</h3>
            <p class="leadership__theme-desc">{theme.description}</p>
          </li>
        ))}
      </ul>
    )
  }

  <div class="leadership__collabs reveal">
    <h3 class="leadership__collabs-heading">{collaborations.title}</h3>
    <ul class="leadership__collabs-list" role="list">
      {
        collaborations.items.map((item) => {
          const href = getEntityUrl(item.entity);
          const src = logoSrc(item.logo);
          if (!href || !src) return null;
          return (
            <li>
              <a
                href={href}
                class="leadership__collab-mark"
                aria-label={item.name}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img src={src} alt="" loading="lazy" />
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</Section>

<style>
  .leadership__statement {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    line-height: var(--lh-tight);
    color: var(--heading);
    max-width: var(--maxw-text);
    margin-bottom: var(--space-6);
  }
  .leadership__bio {
    font-size: 1.05rem;
    max-width: var(--maxw-text);
    margin-bottom: var(--space-10);
    color: var(--text-muted);
    line-height: 1.85;
  }
  .leadership__intro {
    font-size: var(--fs-body);
    max-width: var(--maxw-text);
    margin-top: var(--space-10);
    color: var(--text-muted);
    line-height: var(--lh-body);
  }
  .leadership__diff {
    margin-top: var(--space-10);
  }
  .leadership__diff-heading {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }
  .leadership__diff .leadership__themes {
    margin-top: 0;
  }
  .leadership__themes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--stack-sm);
    list-style: none;
    padding: 0;
    margin: var(--space-10) auto 0;
  }
  .leadership__theme {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: var(--card-padding);
  }
  .leadership__theme-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
  }
  .leadership__theme-title {
    font-size: 1.02rem;
    font-weight: 700;
    color: var(--heading);
    margin: 0;
  }
  .leadership__theme-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: none;
  }
  .leadership__collabs {
    margin-top: var(--space-10);
  }
  .leadership__collabs-heading {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }
  .leadership__collabs-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--space-4);
    width: 80%;
    max-width: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .leadership__collabs-list li {
    min-width: 0;
  }
  .leadership__collab-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    height: clamp(56px, 7vw, 80px);
    padding: var(--space-3) var(--space-4);
    background: var(--logo-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }
  .leadership__collab-mark:hover {
    border-color: var(--accent-light);
    box-shadow: 0 0 0 1px
      color-mix(in srgb, var(--accent-light) 25%, transparent);
  }
  .leadership__collab-mark:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .leadership__collab-mark img {
    display: block;
    max-width: 100%;
    max-height: clamp(36px, 5vw, 52px);
    width: auto;
    height: auto;
    object-fit: contain;
  }
  @media (max-width: 768px) {
    .leadership__collabs-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .leadership__collabs-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: 90%;
    }
  }
</style>
