---
interface Props {
  src: string;
  alt: string;
  webp?: string;
  width?: number;
  height?: number;
  class?: string;
}

const {
  src,
  alt,
  webp,
  width = 480,
  height = 480,
  class: cls,
} = Astro.props;
---

<figure class:list={['portrait', cls]}>
  <div class="portrait__frame">
    {webp ? (
      <picture>
        <source srcset={webp} type="image/webp" />
        <img
          src={src}
          alt={alt}
          width={width}
          height={height}
          loading="eager"
          decoding="async"
        />
      </picture>
    ) : (
      <img
        src={src}
        alt={alt}
        width={width}
        height={height}
        loading="eager"
        decoding="async"
      />
    )}
  </div>
</figure>

<style>
  .portrait {
    margin: 0;
    width: clamp(220px, 30vw, 360px);
    aspect-ratio: 1 / 1;
    position: relative;
  }
  .portrait::before {
    content: '';
    position: absolute;
    inset: 10% 4% 2%;
    border-radius: 42% 38% 44% 40%;
    background:
      radial-gradient(
        circle at 50% 28%,
        color-mix(in srgb, var(--accent-light) 24%, transparent),
        transparent 62%
      ),
      radial-gradient(
        circle at 58% 72%,
        color-mix(in srgb, var(--accent-red-light) 12%, transparent),
        transparent 58%
      );
    filter: blur(10px);
    opacity: 0.8;
    pointer-events: none;
  }
  .portrait__frame {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
    overflow: visible;
    border: 0;
    background: transparent;
    box-shadow: none;
    position: relative;
    isolation: isolate;
  }
  .portrait__frame::before {
    content: none;
  }
  .portrait__frame::after {
    content: none;
  }
  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 18px 28px rgba(0, 0, 0, 0.36));
  }
  @media (prefers-reduced-motion: no-preference) {
    .portrait__frame {
      transition: transform var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }
    .portrait:hover .portrait__frame {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgba(0, 0, 0, 0.5);
    }
  }
</style>
