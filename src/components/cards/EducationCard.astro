---
import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import RecogCardShell from '@components/ui/RecogCardShell.astro';
import { getEntityUrl, logoSrc } from '@lib/content';
import type { EducationRecord } from '@schemas';

type Props = EducationRecord;

const {
  degree,
  institution,
  entity,
  period,
  gpa,
  achievement,
  achievementDetail,
  summary,
} = Astro.props;

const logo = logoSrc(entity);
const entityUrl = getEntityUrl(entity);

function formatGpa(value?: string) {
  if (!value) return undefined;
  return value.toLowerCase().startsWith('cgpa') ? value : `CGPA ${value}`;
}
---

<RecogCardShell class="edu-accent">
  <Fragment slot="headTop">
    {
      logo ? (
        <div class="logo-badge logo-badge--wide">
          <img src={logo} alt={`${institution} logo`} loading="lazy" />
        </div>
      ) : (
        <div class="recog-icon" aria-hidden="true">
          <Icon name="graduation" size={24} />
        </div>
      )
    }
    {achievement && <span class="recog-badge">{achievement}</span>}
  </Fragment>
  <h3 slot="title" class="edu-card-title">{degree}</h3>

  <dl class="recog-card-fields">
    <div class="recog-card-field">
      <dt class="recog-label">Institution</dt>
      <dd class="recog-value">
        {
          entityUrl ? (
            <EntityLink href={entityUrl} label={institution} />
          ) : (
            institution
          )
        }
      </dd>
    </div>
    <div class="recog-card-field">
      <dt class="recog-label">Period</dt>
      <dd class="recog-value">{period}</dd>
    </div>
    {
      gpa && (
        <div class="recog-card-field">
          <dt class="recog-label">GPA</dt>
          <dd class="recog-value">{formatGpa(gpa)}</dd>
        </div>
      )
    }
    {
      achievement && (
        <div class="recog-card-field">
          <dt class="recog-label">Achievement</dt>
          <dd class="recog-value">
            {achievement}
            {achievementDetail && (
              <span class="field-detail"> — {achievementDetail}</span>
            )}
          </dd>
        </div>
      )
    }
  </dl>

  {
    summary && (
      <Fragment slot="footer">
        <div class="recog-card-divider" />
        <div class="recog-card-message">
          <span class="recog-label">Context</span>
          <p class="recog-body">{summary}</p>
        </div>
      </Fragment>
    )
  }
</RecogCardShell>

<style>
  .edu-accent {
    --accent-card: var(--accent-gold);
  }
  .edu-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--accent-card);
    margin: 0;
  }
  .field-detail {
    color: var(--text-muted);
  }
  .recog-card-message .recog-body {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: none;
    margin: 0;
  }
</style>
