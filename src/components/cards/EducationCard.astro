---
import Icon from '@components/ui/Icon.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { getEntityUrl, logoSrc } from '@lib/content';
import type { EducationRecord } from '@schemas';

type Props = EducationRecord;

const {
  degree,
  institution,
  entity,
  period,
  gpa,
  achievement,
  achievementDetail,
  summary,
} = Astro.props;

const logo = logoSrc(entity);
const entityUrl = getEntityUrl(entity);

function formatGpa(value?: string) {
  if (!value) return undefined;
  return value.toLowerCase().startsWith('cgpa') ? value : `CGPA ${value}`;
}
---

<article class="recog-card edu-accent">
  <header class="card-head">
    <div class="card-head-top">
      {
        logo ? (
          <div class="edu-logo">
            <img src={logo} alt={`${institution} logo`} loading="lazy" />
          </div>
        ) : (
          <div class="recog-icon" aria-hidden="true">
            <Icon name="graduation" size={24} />
          </div>
        )
      }
      {achievement && <span class="recog-badge">{achievement}</span>}
    </div>
    <h3 class="card-title">{degree}</h3>
  </header>

  <div class="card-divider"></div>

  <dl class="card-fields">
    <div class="field">
      <dt>Institution</dt>
      <dd>
        {
          entityUrl ? (
            <EntityLink href={entityUrl} label={institution} />
          ) : (
            institution
          )
        }
      </dd>
    </div>
    <div class="field">
      <dt>Period</dt>
      <dd>{period}</dd>
    </div>
    {
      gpa && (
        <div class="field">
          <dt>GPA</dt>
          <dd>{formatGpa(gpa)}</dd>
        </div>
      )
    }
    {
      achievement && (
        <div class="field">
          <dt>Achievement</dt>
          <dd>
            {achievement}
            {achievementDetail && (
              <span class="field-detail"> — {achievementDetail}</span>
            )}
          </dd>
        </div>
      )
    }
  </dl>

  {
    summary && (
      <>
        <div class="card-divider" />
        <div class="card-message">
          <span class="field-label">Context</span>
          <p>{summary}</p>
        </div>
      </>
    )
  }
</article>

<style>
  .edu-accent {
    --accent-card: var(--accent-gold);
  }

  .card-head {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
  }
  .card-head-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .card-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--accent-card);
    margin: 0;
  }
  .edu-logo {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 44px;
    padding: var(--space-2);
    background: var(--logo-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .edu-logo img {
    display: block;
    max-width: 100%;
    max-height: 28px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .card-divider {
    height: 1px;
    background: var(--border);
  }
  .card-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: 0;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .field dt,
  .field-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .field dd {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text);
    max-width: none;
  }
  .field-detail {
    color: var(--text-muted);
  }
  .card-message {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .card-message p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: none;
    margin: 0;
  }
</style>
