---
import SpeakingCard from '@components/cards/SpeakingCard.astro';
import Section from '@components/ui/Section.astro';
import { speakers, site } from '@lib/content';
---

<Section
  id="speakers"
  title={site.sections.speakers.title}
  variant="alt"
  class="section--compact-top"
>
  <div class="speaking-grid reveal">
    {speakers.items.map((item) => <SpeakingCard item={item} />)}
  </div>
</Section>

<style>
  .speaking-grid {
    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(var(--grid-col-min-lg), 1fr)
    );
    gap: var(--stack-md);
  }
</style>
