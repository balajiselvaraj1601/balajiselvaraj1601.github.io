---
import Section from '@components/ui/Section.astro';
import ThemeCard from '@components/cards/ThemeCard.astro';
import VisionHub from '@components/ui/VisionHub.astro';
import { visionBoard, site, logoSrc } from '@lib/content';
import type { VisionBoard } from '@schemas';

type VisionProgram = VisionBoard['programs'][number];

/** Entity slug first, then pipeline badge asset — for uniform rect logo boxes. */
function resolveProgramLogoSlug(p: VisionProgram): string {
  const entity = p.entity;
  if (entity && logoSrc(entity)) return entity;
  if (p.badge?.kind === 'logo' && logoSrc(p.badge.asset)) return p.badge.asset;
  return entity ?? '';
}
---

<Section
  id="vision-programs"
  title={site.sections['vision-programs'].title}
  variant="alt"
  class="section--compact-top section--compact-bottom"
>
  <div class="vision-flow reveal">
    {
      visionBoard.groups && visionBoard.groups.length >= 2 && (
        <>
          <VisionHub group={visionBoard.groups[0]} />

          <span class="vision-flow__chevrons" aria-hidden="true">
            <span class="vision-flow__chevron vision-flow__chevron--1" />
            <span class="vision-flow__chevron vision-flow__chevron--2" />
            <span class="vision-flow__chevron vision-flow__chevron--3" />
          </span>

          <VisionHub group={visionBoard.groups[1]} />

          <span class="vision-flow__chevrons" aria-hidden="true">
            <span class="vision-flow__chevron vision-flow__chevron--1" />
            <span class="vision-flow__chevron vision-flow__chevron--2" />
            <span class="vision-flow__chevron vision-flow__chevron--3" />
          </span>

          {visionBoard.programs && visionBoard.programs.length > 0 && (
            <div class="vision-flow__cards">
              <ul
                class="theme-grid vision-flow__grid"
                style="--theme-cols: 2"
                role="list"
              >
                {visionBoard.programs.map((p) => (
                  <li data-variant={p.variant}>
                    <ThemeCard
                      title={p.title}
                      lines={p.lines}
                      mark={p.badge}
                      slug={p.entity}
                      logoSlug={resolveProgramLogoSlug(p)}
                      markDisplay="rect"
                      altText={p.title}
                      label={p.label}
                      entity={p.entity}
                      accent={false}
                    />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </>
      )
    }
  </div>
</Section>

<style>
  .vision-flow {
    display: grid;
    /* Chevron tracks are `auto` (intrinsic width) and the whole row centres as a
       cluster, so every track-to-track gap equals --vision-flow-gap exactly — no more
       elastic 1fr sprawl, and both chevron sets get symmetric structural gaps. */
    grid-template-columns:
      minmax(260px, var(--vision-hub-max))
      auto
      minmax(260px, var(--vision-hub-max))
      auto
      minmax(300px, var(--vision-cards-max));
    justify-content: center;
    align-items: start;
    column-gap: var(--vision-flow-gap, var(--space-4));
    width: 100%;
  }

  .vision-flow > :global(.vision-hub) {
    width: 100%;
    max-width: var(--vision-hub-max);
    justify-self: center;
    min-width: 0;
  }

  .vision-flow__cards {
    width: 100%;
    max-width: min(100%, var(--vision-cards-max));
    min-width: 0;
    justify-self: start;
    /* The hub is a circle whose ring is inset ~4% from its track edge, while the cards
       are flush to theirs. Nudge the cards right by that inset so chevron set 2 is
       optically centred and the hub↔box visible gap matches the hub↔hub gap.
       transform is post-layout — it doesn't disturb grid track sizing. */
    transform: translateX(var(--vision-hub-ring-inset));
  }

  .vision-flow__chevrons {
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: center;
    min-width: max-content;
    align-self: start;
    gap: 0;
    margin-top: calc(
      var(--vision-hub-stage-mid, 180px) - var(--chevron-flow-h) / 2
    );
  }

  .vision-flow__chevron + .vision-flow__chevron {
    margin-inline-start: calc(-1 * var(--chevron-flow-overlap));
  }

  .vision-flow__chevron {
    width: var(--chevron-flow-w);
    height: var(--chevron-flow-h);
    clip-path: polygon(0% 0%, 48% 0%, 100% 50%, 48% 100%, 0% 100%, 52% 50%);
  }

  .vision-flow__chevron--1 {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent-strong) 75%, var(--bg-elev)),
      var(--accent-strong)
    );
  }

  .vision-flow__chevron--2 {
    background: linear-gradient(135deg, var(--accent-strong), var(--accent));
  }

  .vision-flow__chevron--3 {
    background: linear-gradient(
      135deg,
      var(--accent),
      color-mix(in srgb, var(--accent) 60%, var(--bg))
    );
  }

  .vision-flow__grid {
    margin-top: 0;
  }

  .vision-flow__grid li {
    display: flex;
    min-width: 0;
  }

  /* Row-based accent: purple top row, red bottom row (mirrors About --accent-card). */
  .vision-flow__grid li[data-variant='purple'] {
    --accent-card: var(--accent);
  }

  .vision-flow__grid li[data-variant='red'] {
    --accent-card: var(--accent-red-light);
  }

  /* About-style standalone theme cards (scoped — LeadershipPhilosophy pattern). */
  .vision-flow__grid :global(.theme-card.card) {
    flex: 1;
    height: 100%;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    border-top: 2px solid var(--accent-card, var(--accent));
    padding: var(--card-padding);
  }

  @media (prefers-reduced-motion: no-preference) {
    .vision-flow__grid :global(.theme-card.card) {
      transition:
        transform var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease),
        border-color var(--dur) var(--ease);
    }

    .vision-flow__grid :global(.theme-card.card:hover) {
      transform: translateY(var(--card-lift));
      box-shadow: var(--shadow-md);
      border-color: var(--accent-card, var(--accent));
    }
  }

  .vision-flow__grid :global(.program-card__label) {
    color: var(--accent-card, var(--accent-ll));
  }

  .vision-flow__grid :global(.program-card__lines li) {
    font-size: var(--fs-body);
  }

  /* Uniform white logo slots in each program quadrant. */
  .vision-flow__grid :global(.program-card__mark) {
    display: flex;
    justify-content: center;
    margin-bottom: var(--text-gap-inline);
    width: 100%;
  }

  .vision-flow__grid :global(.program-card__logo) {
    width: 100%;
    max-width: 100%;
  }

  .vision-flow__grid :global(.logo-badge) {
    width: 100%;
    min-height: var(--logo-box-h);
    justify-content: center;
    background: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 8%,
      var(--logo-surface)
    );
    border-color: color-mix(
      in srgb,
      var(--accent-card, var(--accent)) 35%,
      var(--border)
    );
  }

  .vision-flow__grid :global(.logo-badge img) {
    max-height: var(--logo-h-md);
    max-width: var(--logo-w-max-md);
  }

  @media (max-width: 1180px) {
    /* 1180px — matches --bp-2xl (CSS vars invalid in @media features) */
    .vision-flow {
      grid-template-columns: 1fr 1fr 1fr;
      row-gap: var(--space-6);
      --vision-hub-max: var(--vision-hub-max-md);
      --vision-hub-stage-mid: calc(var(--vision-hub-max) / 2);
    }

    .vision-flow > :global(.vision-hub):first-of-type {
      grid-column: 1;
      grid-row: 1;
      width: clamp(200px, 38vw, var(--vision-hub-max-md));
      max-width: var(--vision-hub-max-md);
    }

    .vision-flow > :global(.vision-hub):last-of-type {
      grid-column: 3;
      grid-row: 1;
      width: clamp(200px, 38vw, var(--vision-hub-max-md));
      max-width: var(--vision-hub-max-md);
    }

    .vision-flow__chevrons:first-of-type {
      grid-column: 2;
      grid-row: 1;
    }

    .vision-flow__chevrons:last-of-type {
      display: none;
    }

    .vision-flow__cards {
      grid-column: 1 / -1;
      grid-row: 2;
      max-width: min(100%, var(--vision-cards-max));
      justify-self: center;
      margin-inline: auto;
      /* Stacked layout: cards are centred full-width, so drop the desktop ring-inset nudge. */
      transform: none;
    }
  }

  @media (max-width: 560px) {
    /* 560px — matches --bp-sm */
    .vision-flow__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
