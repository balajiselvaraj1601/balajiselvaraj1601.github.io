---
import Section from '@components/ui/Section.astro';
import Icon from '@components/ui/Icon.astro';
import EducationCard from '@components/cards/EducationCard.astro';
import { education, site } from '@lib/content';

const [record] = education.records;
const gpaValue = record.gpa?.replace(/^CGPA\s*/i, '') ?? '—';
const degreeShort = record.degree.split(' ')[0];
const fieldLabel = record.field ?? record.degree.replace(/^[^\s]+\s*/, '');
---

<Section
  id="education"
  title={site.sections.education.title}
  subtitle={education.intro}
  variant="default"
>
  <div class="recog-summary reveal edu-accent">
    <div class="recog-tile">
      <div class="recog-tile__icon" aria-hidden="true">
        <Icon name="chart" size={22} />
      </div>
      <div class="recog-tile__count">{gpaValue}</div>
      <div class="recog-tile__label">CGPA</div>
    </div>
    <div class="recog-tile">
      <div class="recog-tile__icon" aria-hidden="true">
        <Icon name="trophy" size={22} />
      </div>
      <div class="recog-tile__count">{record.achievement ?? '—'}</div>
      <div class="recog-tile__label">University Rank</div>
    </div>
    <div class="recog-tile">
      <div class="recog-tile__icon" aria-hidden="true">
        <Icon name="calendar" size={22} />
      </div>
      <div class="recog-tile__count">{record.period}</div>
      <div class="recog-tile__label">Years</div>
    </div>
    <div class="recog-tile">
      <div class="recog-tile__icon" aria-hidden="true">
        <Icon name="graduation" size={22} />
      </div>
      <div class="recog-tile__count">{degreeShort}</div>
      <div class="recog-tile__label">{fieldLabel}</div>
    </div>
  </div>

  <div class="edu-card-wrap reveal">
    <EducationCard {...record} />
  </div>
</Section>

<style>
  .edu-accent {
    --accent-card: var(--accent-gold);
  }

  .edu-card-wrap {
    max-width: 720px;
  }
</style>
