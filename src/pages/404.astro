---
import Layout from '@layouts/Layout.astro';
import { profile, site } from '@lib/content';

const notFound = site.ui.notFound;
const title = notFound.titleTemplate.replace('{name}', profile.name);
---

<Layout
  title={title}
  path="/404"
  description={notFound.description}
  singlePageViews={true}
>
  <section class="notfound">
    <div class="container notfound__inner">
      <p class="notfound__code">{notFound.code}</p>
      <h1 class="notfound__title">{notFound.heading}</h1>
      <p class="notfound__text">{notFound.message}</p>
      <div class="notfound__actions">
        <a class="btn btn-primary" href="/">{notFound.backHome}</a>
        <a class="btn" href="/#experience">{notFound.viewExperience}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-24);
  }
  .notfound__code {
    font-family: var(--font-mono);
    font-size: clamp(3rem, 2rem + 6vw, 6rem);
    font-weight: 600;
    color: var(--accent);
    line-height: 1;
  }
  .notfound__title {
    margin-block: var(--space-3) var(--space-3);
  }
  .notfound__text {
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }
  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
