    gap: var(--landing-gap);
    padding-block: var(--space-6);
    overflow: visible;
    background: var(--hero-gradient);
  }

  .about-landing :global(#hero) {
    background: transparent;
  }

  @media (max-width: 1023px) {
    .about-landing {
      height: auto;
