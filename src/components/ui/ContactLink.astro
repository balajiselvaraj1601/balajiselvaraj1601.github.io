---
import Icon from './Icon.astro';
import { resolveIcon } from '@lib/icons';

interface Props {
  label: string;
  value: string;
  href?: string | null;
  icon: string;
}
const { label, value, href, icon } = Astro.props;
const iconName = resolveIcon(icon, 'email');
---

{
  href ? (
    <a
      class="clink"
      href={href}
      {...(href.startsWith('http')
        ? { target: '_blank', rel: 'noopener noreferrer' }
        : {})}
    >
      <span class="clink-icon" aria-hidden="true">
        <Icon name={iconName} size={20} />
      </span>
      <span class="clink-label">{label}</span>
      <span class="clink-val">
        {value}
        {href.startsWith('http') && (
          <span class="visually-hidden"> (opens in new window)</span>
        )}
      </span>
    </a>
  ) : (
    <div class="clink">
      <span class="clink-icon">
        <Icon name={iconName} size={20} />
      </span>
      <span class="clink-label">{label}</span>
      <span class="clink-val">{value}</span>
    </div>
  )
}

<style>
  .clink {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.88rem;
    color: var(--text);
    text-decoration: none;
    padding: 0.85rem 1rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition:
      border-color 0.25s,
      color 0.25s;
  }
  a.clink:hover {
    border-color: var(--accent);
    color: var(--heading);
  }
  .clink-icon {
    width: 24px;
    text-align: center;
    flex-shrink: 0;
    color: var(--accent-light);
  }
  .clink-label {
    font-weight: 500;
  }
  .clink-val {
    margin-left: auto;
    color: var(--text-muted);
    font-size: 0.8rem;
    text-align: right;
  }
</style>
