---
import Section from '@components/Section.astro';
import ContactLink from '@components/ContactLink.astro';
import Icon from '@components/Icon.astro';
import { profile, site, education } from '@lib/content';

const publicContact = profile.contact.filter((c) => c.type !== 'phone');
const edu = education.records[0];
const { contactPage } = profile;

function formatGpa(gpa?: string) {
  if (!gpa) return '';
  return gpa.toLowerCase().startsWith('cgpa') ? gpa : `CGPA ${gpa}`;
}
---

<Section id="contact" title={contactPage.title} eyebrow={contactPage.eyebrow} variant="alt">
  <div class="contact-layout reveal">
    <div class="contact-left">
      <p class="contact-subtitle">{profile.contactIntro}</p>
      <div class="contact-links">
        {
          publicContact.map((c) => (
            <ContactLink
              label={c.label}
              value={c.value}
              href={c.href}
              icon={c.icon}
            />
          ))
        }
      </div>

      {
        edu && (
          <div class="edu-block">
            <div class="edu-icon" aria-hidden="true">
              <Icon name="graduation" size={24} />
            </div>
            <div class="edu-text">
              <h4>Education</h4>
              <h3>{edu.degree}</h3>
              <p>
                {edu.institution} · {edu.period}
                {edu.gpa && ` · ${formatGpa(edu.gpa)}`}
              </p>
            </div>
            {
              edu.achievement && (
                <div class="gold-badge">{edu.achievement}</div>
              )
            }
          </div>
        )
      }
    </div>

    <div class="contact-right">
      <h3 class="contact-right__title">{contactPage.interestsHeading}</h3>
      <ul class="interests-list">
        {profile.contactInterests.map((interest) => (
          <li>{interest}</li>
        ))}
      </ul>

      <div class="cv-card card">
        <p class="eyebrow">{contactPage.resumeEyebrow}</p>
        <p class="cv-desc">{contactPage.resumeDescription}</p>
        <a class="btn btn-primary" href={site.resume.path} target="_blank" rel="noopener noreferrer">
          {contactPage.resumeLabel}
        </a>
      </div>
    </div>
  </div>
</Section>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 1rem;
  }
  .contact-subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.95rem;
    max-width: none;
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .edu-block {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .edu-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-ll);
  }
  .edu-text h4 {
    margin-bottom: 0.3rem;
  }
  .edu-text h3 {
    font-size: 0.95rem;
    font-weight: 700;
  }
  .edu-text p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    max-width: none;
  }
  .gold-badge {
    margin-left: auto;
    background: linear-gradient(135deg, #f5c518, #c8960c);
    color: #000;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }
  .contact-right__title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.75rem;
  }
  .interests-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .interests-list li {
    font-size: 0.88rem;
    padding-left: 1rem;
    position: relative;
    max-width: none;
  }
  .interests-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent-light);
    font-size: 0.7rem;
  }
  .cv-card {
    padding: 1.5rem;
    text-align: center;
  }
  .cv-desc {
    font-size: 0.83rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    max-width: none;
  }
  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
