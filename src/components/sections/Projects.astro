---
import Section from '@components/ui/Section.astro';
import Chip from '@components/ui/Chip.astro';
import EntityLink from '@components/ui/EntityLink.astro';
import { projects, site, getEntityUrl } from '@lib/content';

const title = site.sections.projects.title;

const MAX_VISIBLE_TAGS = 3;

const others = projects.projects.filter((p) => !p.featured);
const groupDefs = projects.groups ?? [];
const groups = groupDefs
  .map((group) => ({
    heading: group.heading,
    items: others.filter((p) => p.group === group.id),
  }))
  .filter((g) => g.items.length > 0);
---

<Section id="projects" title={title} eyebrow="Other Work" variant="default">
  <div class="proj-groups reveal">
    {
      groups.map((group) => (
        <div class="proj-group">
          <h3 class="proj-group__heading">{group.heading}</h3>
          <ul class="proj-grid">
            {group.items.map((p) => (
              <li class="proj-compact card">
                <p class="pc-meta">
                  <span>{p.domain}</span>
                  <span class="pc-dot" aria-hidden="true">
                    ·
                  </span>
                  <span>{p.period}</span>
                </p>
                <h4 class="pc-name">{p.name}</h4>
                <p class="pc-role">
                  {p.role} ·{' '}
                  <EntityLink href={getEntityUrl(p.entity)} label={p.org} />
                </p>
                <p class="pc-summary">{p.summary}</p>
                {p.highlights.length > 0 && (
                  <ul class="pc-highlights">
                    {p.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                )}
                {p.tags.length > 0 && (
                  <ul class="pc-tags" aria-label="Project tags">
                    {p.tags.slice(0, MAX_VISIBLE_TAGS).map((t) => (
                      <li>
                        <Chip>{t}</Chip>
                      </li>
                    ))}
                    {p.tags.length > MAX_VISIBLE_TAGS && (
                      <li>
                        <Chip class="pc-tag-more">
                          +{p.tags.length - MAX_VISIBLE_TAGS} more
                        </Chip>
                      </li>
                    )}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>

<style>
  .proj-groups {
    display: flex;
    flex-direction: column;
    gap: var(--stack-xl);
  }
  .proj-group__heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent-ll);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border);
  }
  .proj-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--stack-md);
  }
  .proj-compact {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .pc-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin: 0;
  }
  .pc-dot {
    margin-inline: 0.35rem;
  }
  .pc-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--heading);
    margin: 0;
  }
  .pc-role {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }
  .pc-summary {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    flex: 1;
  }
  .pc-highlights {
    list-style: disc;
    padding-left: 1.2rem;
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .pc-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .pc-tag-more {
    opacity: 0.75;
  }
</style>
