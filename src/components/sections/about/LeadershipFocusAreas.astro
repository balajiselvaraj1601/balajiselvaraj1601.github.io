---
import CardMark from '@components/ui/CardMark.astro';
import { profile } from '@lib/content';

const {
  blockHeadings,
  strategicVision,
  businessImpact,
  platform,
  peopleMentoring,
  governanceAI,
  governancePrivacy,
  governanceGxP,
} = profile.leadershipPhilosophy;

const cardBlocks = [
  {
    key: 'strategicVision',
    heading: blockHeadings.strategicVision,
    items: strategicVision,
  },
  {
    key: 'businessImpact',
    heading: blockHeadings.businessImpact,
    items: businessImpact,
  },
  { key: 'platform', heading: blockHeadings.platform, items: platform },
  {
    key: 'peopleMentoring',
    heading: blockHeadings.peopleMentoring,
    items: peopleMentoring,
  },
  {
    key: 'governanceAI',
    heading: blockHeadings.governanceAI,
    items: governanceAI,
  },
  {
    key: 'governancePrivacy',
    heading: blockHeadings.governancePrivacy,
    items: governancePrivacy,
  },
  {
    key: 'governanceGxP',
    heading: blockHeadings.governanceGxP,
    items: governanceGxP,
  },
];
const visibleBlocks = cardBlocks.filter((b) => b.items && b.items.length > 0);
---

<div
  class="leadership__filters reveal"
  role="group"
  aria-label="Filter About focus areas"
>
  <button
    type="button"
    class="recog-chip is-active"
    data-filter="all"
    aria-pressed="true"
  >
    All
  </button>
  {
    visibleBlocks.map((b) => (
      <button
        type="button"
        class:list={['recog-chip', `cat-${b.key}`]}
        data-filter={b.key}
        aria-pressed="false"
      >
        {b.heading}
      </button>
    ))
  }
</div>

<div class="leadership__blocks" data-about-grid>
  {
    visibleBlocks.map(({ key, heading, items }) => (
      <div
        class:list={['leadership__card-row', 'reveal', `cat-${key}`]}
        data-category={key}
      >
        <h3 class="leadership__diff-heading">{heading}</h3>
        <ul class="theme-grid" role="list">
          {(items ?? []).map((item) => (
            <li class="theme-card card">
              {item.icon && <CardMark icon={item.icon} context="theme-card" />}
              <h3 class="theme-card__title">{item.title}</h3>
              <p class="theme-card__desc">{item.description}</p>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<style>
  .leadership__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0 0 var(--text-gap-inline);
  }
  .leadership__card-row.hidden {
    display: none;
  }

  /* Per-category token mapping — one hue per category key. Mirrors the Awards
     pattern (level → --lvl → --accent-card); keys match data-category so
     theming and filtering share one source. */
  .cat-strategicVision {
    --cat: var(--about-cat-strategic);
  }
  .cat-businessImpact {
    --cat: var(--about-cat-impact);
  }
  .cat-platform {
    --cat: var(--about-cat-platform);
  }
  .cat-peopleMentoring {
    --cat: var(--about-cat-people);
  }
  .cat-governanceAI {
    --cat: var(--about-cat-ai);
  }
  .cat-governancePrivacy {
    --cat: var(--about-cat-privacy);
  }
  .cat-governanceGxP {
    --cat: var(--about-cat-gxp);
  }
  /* Per-group colour: each leadership row carries its own curated hue via --cat
     (set by its .cat-* class); cards, borders, and icon marks inherit it. */
  .leadership__card-row {
    --accent-card: var(--cat);
    --mark-fg: var(--accent-card);
  }
  /* Active category chip takes its hue; the "All" chip has no .cat-* class, so
     it falls back to the brand purple. */
  .recog-chip.is-active {
    --accent-card: var(--cat, var(--view-accent-about));
    --mark-fg: var(--accent-card);
  }
  /* Dark-mode prominence wash is built into the base `.card` rule (global.css),
     keyed to --accent-card (== --cat on each row). */

  .leadership__diff-heading {
    font-size: var(--fs-eyebrow);
    font-family: var(--font-mono);
    font-weight: var(--fw-regular);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent-card, var(--accent-ll));
    margin-bottom: var(--text-gap-block);
  }

  .leadership__blocks {
    display: flex;
    flex-direction: column;
    gap: var(--stack-xl);
  }

  .leadership__card-row {
    margin-top: 0;
  }
  .leadership__card-row .theme-grid {
    margin-top: 0;
  }
</style>
